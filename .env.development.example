# ==============================================================================
# DJANGO CONFIGURATION
# ==============================================================================
# Clave secreta de Django — usada para firmar cookies, sesiones, CSRF, etc.
DJANGO_SECRET_KEY=insecure-dev-key-change-in-production
# True en desarrollo, False en producción
DJANGO_DEBUG=True
# Hosts permitidos separados por coma
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# "local" para PostgreSQL directo, "neon" para Neon Tech cloud
DB_PROVIDER=local
# Solo aplica si DB_PROVIDER=local
DB_NAME=icm_db
DB_USER=icm_user
DB_PASSWORD=icm_password
DB_HOST=localhost
DB_PORT=5432

# ==============================================================================
# EMAIL CONFIGURATION (SMTP Gmail)
# ==============================================================================
# Usar app password de Google (no la contraseña normal)
# Generar en: Cuenta Google → Seguridad → Verificación en dos pasos → Contraseñas de aplicación
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-correo@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password-gmail

# ==============================================================================
# JWT CONFIGURATION
# ==============================================================================
# Tokens más largos en desarrollo para no re-loguearse seguido
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=1440
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================
APP_TIMEZONE=America/Bogota
INVOICE_SEQUENCE_PREFIX=ICM
# URL del frontend (usada en emails de recuperación de contraseña)
FRONTEND_URL=http://localhost:5173
# Minutos de validez del enlace de recuperación de contraseña
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=60

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# ==============================================================================
# SEED / USUARIO INICIAL
# ==============================================================================
# Usuario almacenista inicial creado por create_almacenista
ALMACENISTA_USERNAME=almacenista
ALMACENISTA_EMAIL=almacenista@icm.local
# Cambiar por contraseña segura antes de producción
ALMACENISTA_PASSWORD=change-me-in-production
