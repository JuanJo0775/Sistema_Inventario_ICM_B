# ==============================================================================
# DJANGO CONFIGURATION
# ==============================================================================
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development

# ============================================================================== 
# CORS CONFIGURATION
# ============================================================================== 
# CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ==============================================================================
# DATABASE CONFIGURATION (Configuración para base de datos local)
# ==============================================================================
DB_NAME=icm_db
DB_USER=icm_user
DB_PASSWORD=icm_password
DB_HOST=localhost
DB_PORT=5432

# ==============================================================================
# JWT CONFIGURATION
# ==============================================================================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================
APP_TIMEZONE=America/Bogota
INVOICE_SEQUENCE_PREFIX=ICM

# ==============================================================================
# SEED / USUARIO INICIAL
# ==============================================================================
# Usuario almacenista inicial (seed) — requerido antes de ejecutar create_almacenista
ALMACENISTA_USERNAME=almacenista
ALMACENISTA_EMAIL=almacenista@icm.local
# OBLIGATORIO: cambiar por contraseña segura antes de ejecutar create_almacenista
ALMACENISTA_PASSWORD=change-me-in-production

# ==============================================================================
# NOTAS DE PRECIOS Y FACTURACION
# ==============================================================================
# Los productos se importan sin precios por defecto (todos los campos de precio son null).
# Para cargar precios:
#   Opción A: PATCH /api/v1/catalog/products/<id>/prices/ (endpoint individual)
#   Opción B: Agregar columnas de precio al Excel (ver docs/pricing/README_PRECIOS_FACTURACION.md)
# Los precios se congelan en el Movement al momento del despacho (BR-16).
# Todo cambio de precio queda registrado en ProductPriceHistory (BR-17).

# ==============================================================================
# OPTIONAL — Prepared for future phases (do not implement yet)
# ==============================================================================
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0

# ==============================================================================
# EMAIL CONFIGURATION (Production)
# ==============================================================================
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# ==============================================================================
