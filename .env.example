# ==============================================================================
# DJANGO CONFIGURATION
# ==============================================================================
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development

# ============================================================================== 
# CORS CONFIGURATION
# ============================================================================== 
# CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# DB_PROVIDER determina qué base de datos usar:
#   "local" → usa DB_NAME/DB_USER/DB_PASSWORD/DB_HOST/DB_PORT (PostgreSQL local)
#   "neon"  → usa DATABASE_URL (conexión a Neon Tech cloud)
DB_PROVIDER=local

# --- Opción A: Local PostgreSQL ---
DB_NAME=icm_db
DB_USER=icm_user
DB_PASSWORD=icm_password
DB_HOST=localhost
DB_PORT=5432

# --- Opción B: Neon Tech (nube) ---
# Descomenta DB_PROVIDER=neon y completa tu DATABASE_URL:
# DB_PROVIDER=neon
# DATABASE_URL=postgresql://neondb_owner:password@ep-xxxx.sa-east-1.aws.neon.tech/neondb?sslmode=require

# ==============================================================================
# JWT CONFIGURATION
# ==============================================================================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================
APP_TIMEZONE=America/Bogota
INVOICE_SEQUENCE_PREFIX=ICM

# ==============================================================================
# SEED / USUARIO INICIAL
# ==============================================================================
# Usuario almacenista inicial (seed) — requerido antes de ejecutar create_almacenista
ALMACENISTA_USERNAME=almacenista
ALMACENISTA_EMAIL=almacenista@icm.local
# OBLIGATORIO: cambiar por contraseña segura antes de ejecutar create_almacenista
ALMACENISTA_PASSWORD=change-me-in-production


# ==============================================================================
# OPTIONAL — Prepared for future phases (do not implement yet)
# ==============================================================================
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0

# ==============================================================================
# EMAIL CONFIGURATION
# ==============================================================================
# Gmail SMTP — requiere contraseña de aplicación de Google (no la contraseña normal)
# Generar en: Cuenta Google → Seguridad → Verificación en dos pasos → Contraseñas de aplicación
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=tu-cuenta@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password-de-google
EMAIL_PORT=587
EMAIL_USE_TLS=True


# ==============================================================================
# FRONTEND CONFIGURATION
# ==============================================================================
# URL base del frontend (usada en los emails de recuperación de contraseña)
# Desarrollo (Vite): FRONTEND_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Producción: FRONTEND_URL=https://tuapp.com

# ==============================================================================
# PASSWORD RECOVERY
# ==============================================================================
# Minutos de validez del enlace de recuperación de contraseña (default: 10)
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=10
