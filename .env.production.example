# ==============================================================================
# DJANGO CONFIGURATION
# ==============================================================================
# Clave secreta de Django — generar una segura con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production
# Siempre False en producción
DJANGO_DEBUG=False
# Dominios permitidos separados por coma
DJANGO_ALLOWED_HOSTS=api.icm.com.co

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# Opción A: Neon (nube) — descomentar y completar:
#   DB_PROVIDER=neon
#   DATABASE_URL=postgresql://usuario:password@ep-xxxx.sa-east-1.aws.neon.tech/dbname?sslmode=require

# Opción B: Local / VPS (PostgreSQL directo) — comentar las de arriba y usar:
#   DB_PROVIDER=local
#   DB_NAME=icm_db_prod
#   DB_USER=icm_user_prod
#   DB_PASSWORD=change-me-password
#   DB_HOST=localhost
#   DB_PORT=5432
DB_PROVIDER=neon
DATABASE_URL=postgresql://username:password@ep-xxxx.sa-east-1.aws.neon.tech/dbname?sslmode=require

# ==============================================================================
# EMAIL CONFIGURATION (SMTP Gmail)
# ==============================================================================
# Usar app password de Google (no la contraseña normal)
# Generar en: Cuenta Google → Seguridad → Verificación en dos pasos → Contraseñas de aplicación
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=notificaciones@icm.com.co
EMAIL_HOST_PASSWORD=your-gmail-app-password

# ==============================================================================
# JWT CONFIGURATION
# ==============================================================================
# Tokens cortos por seguridad
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================
APP_TIMEZONE=America/Bogota
INVOICE_SEQUENCE_PREFIX=ICM
# URL del frontend en producción (usada en emails de recuperación)
FRONTEND_URL=https://app.icm.com.co
# Minutos de validez del enlace de recuperación de contraseña
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=10

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
# Solo el dominio de producción
CORS_ALLOWED_ORIGINS=https://app.icm.com.co

# ==============================================================================
# SEED / USUARIO INICIAL
# ==============================================================================
ALMACENISTA_USERNAME=almacenista
ALMACENISTA_EMAIL=almacenista@icm.com.co
# Cambiar por una contraseña segura
ALMACENISTA_PASSWORD=change-me-in-production
